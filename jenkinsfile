pipeline {
    agent any 
    stages {
        stage('pull') { 
            steps {
               git branch: 'main', url: 'https://github.com/abhaydhangar0011/eks-terraform.git' 
            }
        }
        stage('init') { 
            steps {
                sh ''' terraform init
                       terraform plan'''
            }
        }
        stage('approve') { 
            steps {
                input message: 'shall we procced ?', ok: 'approve'
            }
}
stage('apply') { 
            steps {
                sh ''' terraform destroy --auto-approve
                '''
              echo "apply succesfully"
            }
        }
        stage('Terraform Destroy') {
    steps {
        timeout(5) {
            input message: 'Do you want to destroy the infrastructure?', ok: 'Destroy'
        }

        sh 'terraform destroy --auto-approve'
    }
}
      
    }
}
